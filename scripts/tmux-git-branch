#!/usr/bin/env bash

set -euo pipefail

path=${1:-}

if [[ -z $path || ! -d $path ]]; then
  exit 0
fi

branch=$(git -C "$path" branch --show-current 2>/dev/null || true)
if [[ -z $branch ]]; then
  branch=$(git -C "$path" rev-parse --short HEAD 2>/dev/null || true)
fi

if [[ -n $branch ]]; then
  printf '#[fg=#f5c2e7,bg=default]î‚¶#[fg=#1e1e2e,bg=#f5c2e7,bold] îśĄ #[fg=#cdd6f4,bg=#45475a,bold]  %s  #[fg=#45475a,bg=default]î‚´  \n' "$branch"
fi
